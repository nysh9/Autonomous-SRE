# Copy to .env and fill in. The agent layer (later days) reads these.
# Leave ANTHROPIC_API_KEY blank to use the offline mock-model fallback.
ANTHROPIC_API_KEY=

# Cheap model for triage, strong model for diagnosis (the cost-lever split).
TRIAGE_MODEL=claude-haiku-4-5-20251001
DIAGNOSE_MODEL=claude-opus-4-8

# Where the agent reaches the system under observation.
SYSTEM_BASE_URL=http://localhost:8000
